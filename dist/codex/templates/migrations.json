{
  "schema_version": "1.0.0",
  "plugin_version": "0.8.0",
  "migrations": [
    {
      "from": "0.1.0",
      "to": "0.2.0",
      "steps": [
        {
          "file": ".add/config.json",
          "action": "add_fields",
          "params": {
            "fields": {
              "collaboration.autonomy_level": "balanced",
              "collaboration.team_size": "solo",
              "collaboration.commit_review_gate": false,
              "collaboration.pr_review_gate": true,
              "collaboration.deploy_approval_required": false,
              "source_control.branching": "feature-branches",
              "source_control.default_branch": "main",
              "source_control.commit_convention": "conventional",
              "source_control.pr_template": true,
              "source_control.protected_branches": ["main"]
            }
          },
          "description": "Add collaboration and source_control sections to config"
        }
      ]
    },
    {
      "from": "0.2.0",
      "to": "0.3.0",
      "steps": [
        {
          "file": ".add/config.json",
          "action": "add_fields",
          "params": {
            "fields": {
              "planning.current_milestone": null,
              "planning.current_cycle": null,
              "planning.wip_limit": 4,
              "planning.parallel_agents": 2,
              "planning.cycle_history": []
            }
          },
          "description": "Add planning section to config for milestone/cycle tracking"
        },
        {
          "file": ".add/handoff.md",
          "action": "restructure",
          "params": {
            "required_sections": ["In Progress", "Completed This Session", "Decisions Made", "Blockers", "Next Steps"],
            "header": "# Session Handoff\n**Written:** {date}"
          },
          "description": "Ensure handoff has all required sections"
        }
      ]
    },
    {
      "from": "0.3.0",
      "to": "0.4.0",
      "steps": [
        {
          "file": ".add/learnings.md",
          "action": "convert_md_to_json",
          "params": {
            "target": ".add/learnings.json",
            "template": "templates/learnings.json.template",
            "id_prefix": "L",
            "default_scope": "project",
            "regenerate_md": true
          },
          "description": "Convert freeform learnings markdown to structured JSON with tags"
        },
        {
          "file": "~/.claude/add/library.md",
          "action": "convert_md_to_json",
          "params": {
            "target": "~/.claude/add/library.json",
            "template": "templates/library.json.template",
            "id_prefix": "WL",
            "default_scope": "workstation",
            "regenerate_md": true
          },
          "description": "Convert freeform library markdown to structured JSON with tags"
        },
        {
          "file": ".add/observations.md",
          "action": "restructure",
          "params": {
            "required_format": "{YYYY-MM-DD HH:MM} | {operation} | {summary} | {cost/benefit}",
            "header": "# Process Observations"
          },
          "description": "Ensure observations file has correct header and line format"
        }
      ]
    },
    {
      "from": "0.4.0",
      "to": "0.5.0",
      "steps": [],
      "description": "Plugin restructure — no config migration needed, directory layout change only"
    },
    {
      "from": "0.5.0",
      "to": "0.6.0",
      "steps": [
        {
          "file": ".add/config.json",
          "action": "add_fields",
          "params": {
            "fields": {
              "branding.accentColor": "#b00149",
              "branding.presetName": "raspberry",
              "branding.palette.accent": "#b00149",
              "branding.palette.accentLight": "#d4326d",
              "branding.palette.accentDark": "#8a0038",
              "imageGeneration.enabled": false,
              "imageGeneration.tool": null,
              "imageGeneration.nudged": false,
              "changelog.lastProcessedCommit": null,
              "changelog.lastVersionTag": null
            }
          },
          "description": "Add branding palette, image generation, and changelog fields"
        }
      ]
    },
    {
      "from": "0.6.0",
      "to": "0.7.0",
      "steps": [
        {
          "file": ".add/config.json",
          "action": "add_fields",
          "params": {
            "fields": {
              "quality.e2e_required": false,
              "quality.screenshot_protocol": false
            }
          },
          "description": "Add quality fields for e2e and screenshot protocol (v0.7 compliance rule uses these)"
        }
      ],
      "description": "v0.7 architecture extraction (core/ + runtimes/) — no config schema break, but fields added for compliance rule"
    },
    {
      "from": "0.7.0",
      "to": "0.7.3",
      "steps": [],
      "description": "v0.7.1-v0.7.3: hardening, GPG signing, deploy confirm-phrase gate. No config schema changes — improvements are in rules and skills only."
    },
    {
      "from": "0.7.0",
      "to": "0.8.0",
      "steps": [
        {
          "file": ".add/config.json",
          "action": "add_fields",
          "params": {
            "fields": {
              "learnings.active_cap": 15,
              "learnings.archival_days": 90,
              "learnings.archival_max_severity": "medium"
            }
          },
          "description": "Add configurable learnings thresholds (active view cap and archival age)"
        },
        {
          "file": ".add/learnings.json",
          "action": "run_hook",
          "params": {
            "script": "hooks/filter-learnings.sh",
            "args": ["{file}"],
            "notify": "Generated .add/learnings-active.md — agents now read this compact view instead of the full JSON (72% smaller)."
          },
          "description": "Generate pre-filtered active view of project learnings"
        },
        {
          "file": "~/.claude/add/library.json",
          "action": "run_hook",
          "params": {
            "script": "hooks/filter-learnings.sh",
            "args": ["{file}"],
            "notify": "Generated ~/.claude/add/library-active.md — compact cross-project learning view."
          },
          "description": "Generate pre-filtered active view of cross-project library"
        }
      ],
      "description": "Learnings optimization — v0.7.x projects hop directly to 0.8.0"
    }
  ]
}
