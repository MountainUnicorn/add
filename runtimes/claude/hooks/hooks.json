{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty' 2>/dev/null || true); if echo \"$CMD\" | grep -q 'git push'; then OUT=$(\"${CLAUDE_PLUGIN_ROOT}/lib/scan-secrets.sh\" 2>&1); RC=$?; if [ $RC -ne 0 ]; then echo \"[ADD-SEC advisory] scan-secrets exit=$RC — review before pushing:\" >&2; echo \"$OUT\" >&2; fi; fi; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/post-write.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/post-write.sh\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-scan.sh\""
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-scan.sh\""
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-scan.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -q 'git push' && [ -f CHANGELOG.md ]; then echo '[ADD] CHANGELOG.md exists — run /add:changelog to update it before pushing.'; fi"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-scan.sh\""
          }
        ]
      }
    ]
  }
}
